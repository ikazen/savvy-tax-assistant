# Database (Postgres + pgvector)
DATABASE_URL=postgresql+asyncpg://savvy:savvy@localhost:5432/savvy

# Provider selection
LLM_PROVIDER=ollama          # ollama | gemini
EMBEDDING_PROVIDER=gemini    # ollama | gemini
VECTOR_STORE=pgvector        # pgvector | qdrant | milvus

# 임베딩 벡터 차원 (선택한 모델의 출력 차원과 일치해야 함; 변경 시 DB 재마이그레이션 필요)
EMBED_DIMENSION=768

# Ollama
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_CHAT_MODEL=qwen2.5:14b
OLLAMA_EMBED_MODEL=bge-m3

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBED_MODEL=gemini-embedding-2

# Tenancy
DEFAULT_TENANT_ID=default
